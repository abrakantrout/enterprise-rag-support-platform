# Application Environment Configurations
APP_NAME="Enterprise AI Knowledge Platform"
APP_VERSION="1.0.0"
LOG_LEVEL="INFO"
LOG_FILE="logs/app.log"
UPLOADS_DIR="uploads"

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@db:5432/rag_db"

# ChromaDB Configuration
CHROMA_HOST="chroma"
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME="enterprise_knowledge_chunks"
TOP_K_RESULTS=5
MIN_SIMILARITY_SCORE=0.70
MAX_CONTEXT_CHUNKS=5
MAX_CONTEXT_CHARACTERS=6000

# AI Provider Configuration (mock for foundation stage)
GEMINI_API_KEY="your-gemini-api-key-here"
GOOGLE_API_KEY=""
EMBEDDING_MODEL="models/text-embedding-004"
GEMINI_MODEL="models/gemini-1.5-flash"
TEMPERATURE=0.0
MAX_OUTPUT_TOKENS=1024
REQUEST_TIMEOUT_SECONDS=30

# Chunking Configurations
CHUNK_SIZE=500
CHUNK_MAX_SIZE=700
CHUNK_OVERLAP=50
